# ChurchFlow environment configuration.
# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Supabase (required) — public-by-design anon key, NOT the service role key.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Bible translation lookup (optional).
# Without these, only the offline KJV seed and bible-api.com free fallback are available.
# Sign up for a free key at https://scripture.api.bible/
EXPO_PUBLIC_BIBLE_API_KEY=
# Per-translation Bible IDs from api.bible. The KJV default below works without a key.
EXPO_PUBLIC_BIBLE_ID_KJV=de4e12af7f28f599-01
EXPO_PUBLIC_BIBLE_ID_ESV=
EXPO_PUBLIC_BIBLE_ID_NIV=
EXPO_PUBLIC_BIBLE_ID_NLT=

# Error reporting (optional). When set, runtime errors and unhandled exceptions
# are forwarded to Sentry. Leave blank in development to fall through to console.
EXPO_PUBLIC_SENTRY_DSN=
# Free-form release identifier; used by Sentry to group events by build.
# Common pattern: "churchflow@${appVersion}+${gitSha}".
EXPO_PUBLIC_APP_RELEASE=

# Backend bulk import (used only by scripts/bulk_import_members.ts — NEVER ship
# the service role key to a client build).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
