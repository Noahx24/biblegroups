{
  "expo": {
    "name": "ChurchFlow",
    "slug": "churchflow",
    "scheme": "churchflow",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#FAF6EC",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.churchflow"
    },
    "android": {
      "package": "com.example.churchflow",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B0202C"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "ChurchFlow needs access to your photos to let you set a profile picture."
        }
      ]
    ]
  }
}
