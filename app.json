{
  "expo": {
    "name": "Class Meeting",
    "slug": "class-meeting",
    "scheme": "classmeeting",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#FAF6EE",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.classmeeting"
    },
    "android": {
      "package": "com.example.classmeeting",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#A8232E"
      }
    }
  }
}
